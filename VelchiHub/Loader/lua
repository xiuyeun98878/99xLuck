local function createLED(parent, size, pos)
	local led = Instance.new("Frame")
	led.Parent = parent
	led.Size = size
	led.Position = pos
	led.BackgroundColor3 = Color3.fromRGB(255, 230, 120)
	led.BorderSizePixel = 0

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = led

	return led
end

